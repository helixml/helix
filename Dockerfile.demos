FROM golang:1.25-alpine3.22@sha256:26b4d7113039cd51356bd7930ecafd1031d2975dc3b6940ec8ed09457e17cf95
WORKDIR /app
RUN apk add --no-cache bash openssh
COPY go.mod go.sum ./
# Module resolution needs the replace target (see PR #2286).
COPY helix-org/go.mod helix-org/go.sum ./helix-org/
RUN go mod download
COPY demos ./demos
COPY helix-org ./helix-org
WORKDIR /app/demos
RUN go build -o /demos
EXPOSE 80
ENTRYPOINT [ "/demos" ]
